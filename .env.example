# Apple notarization credentials — copy to .env and fill in.
# .env is gitignored; never commit real values.

# Your Apple ID email (the one enrolled in the Developer Program).
APPLE_ID=

# App-specific password from appleid.apple.com -> Sign-In and Security
# -> App-Specific Passwords. Looks like: xxxx-xxxx-xxxx-xxxx
APPLE_PASSWORD=

# Apple Developer Team ID.
APPLE_TEAM_ID=NFS22LSQRC

# Signing identity (already set in tauri.conf.json, included for reference).
APPLE_SIGNING_IDENTITY="Developer ID Application: Christopher Cook (NFS22LSQRC)"
